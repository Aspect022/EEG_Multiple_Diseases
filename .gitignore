# ==============================================
# EEG Sleep Staging Pipeline — .gitignore
# ==============================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.eggs/
dist/
build/
*.so
pytest-cache-files-*/

# --- Virtual Environment ---
venv/
ENV/
env/
.venv/

# --- Dataset (too large for git, ~33GB) ---
data/ds005555/
data/ds005555_cache/

# --- Model checkpoints (large .pt files) ---
# Keep results.json and CSVs, skip big model files
outputs/results/*/fold_*/best_model.pt
outputs/results/*/fold_*/checkpoint_*.pt
*.ckpt

# --- Monitoring local files ---
wandb/
runs/
session.qwen/

# --- OS & IDE ---
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# --- Logs ---
logs/
*.log
pipeline.log
pipeline.pid
nohup.out

# --- Temp files ---
*.tmp

# --- Results ---
results/ALLResults.csv
results/wandb_export_*.csv

# ==============================================
# KEPT IN GIT (syncs from server → local):
#   outputs/results/*/results.json
#   outputs/results/*/fold_*/training_history.csv
#   outputs/results/*/error.json
#   outputs/results/experiment_summary.json
#   outputs/results/experiment_summary.md
# ==============================================
